# Contact form configuration.
# setup-website.sh writes these to .env.local and pushes them to Vercel automatically.
# This file documents the required variables; do NOT commit secrets here.

# ── Agency-shared (same across all client projects) ──
# Sourced from ~/.config/website-redesign-kit/agency.env when running setup-website.sh.
# See .claude-plugin/skills/contact-form/references/agency-setup.md for the one-time setup.
# CONTACT_FROM_EMAIL is the bare address only — the action prepends CONTACT_SITE_NAME
# at send time so each client's emails appear from their own brand.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=contact@forms.youragency.com

# ── Per-site ──
CONTACT_RECIPIENT_EMAIL=
CONTACT_SITE_NAME=

# Display name shown in the recipient's inbox (the "From" line).
# Describes what the email IS, not which brand sent it — recipients already
# know the brand because the message lands in their own mailbox. A descriptive
# label like "Ny Kundehenvendelse" reads better than a brand name repeat.
# Optional; falls back to CONTACT_SITE_NAME if unset.
CONTACT_FROM_NAME=Ny Kundehenvendelse

# Optional: subject prefix in outgoing emails. Defaults to "[<CONTACT_SITE_NAME>]".
# CONTACT_SUBJECT_PREFIX="[Acme website]"
